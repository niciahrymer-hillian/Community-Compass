# ignore node and dependency files
node_modules/
.DS_Store
*.log

# secrets — never commit real env files (.env.example is the tracked template)
.env
.env.*
!.env.example
**/.env
!**/.env.example

# python
.venv/
**/.venv/
__pycache__/
*.pyc
.pytest_cache/

# local databases
*.db
*.sqlite3

# editor
.vscode/

# frontend build output
dist/
**/dist/

# java / maven build output
target/
**/target/
